<%- include ('partials/header') %>
<main>
    <h1><%= title %></h1>

    <div class="organization-form">
    <form action="/edit-organization/<%= organizationDetails.organization_id %>" method="POST">
        <div class="form-group">
        <label for="name">Organization Name:</label>
        <input 
        type="text" 
        id="name" 
        name="name" 
        value="<%= organizationDetails.organization_name %>"
        maxlength="150"
        required />
        </div>
        
        <div class="form-group">
        <label for="contactEmail">Contact Email:</label>
        <input 
        type="email" 
        id="contactEmail" 
        name="contactEmail"
        maxlength="255"
        value="<%= organizationDetails.contact_email %>" 
        required>
        </div>

        <div class="form-group">
        <label for="description">Description:</label>
        <textarea 
        id="description" 
        name="description"
        maxlength="500"
        required><%= organizationDetails.description %></textarea>
        </div>

        <div class="form-group">
        <label for="logoFilename">Logo Filename:</label>
        <input 
        type="text" 
        id="logoFilename" 
        name="logoFilename" 
        value="<%= organizationDetails.logo_filename %>"
        maxlength="255"
         />

                <div class="category-actions">
                    <button class="btn btn-primary" type="submit">Update Organization</button>
                    <a class="btn btn-secondary" href="/organizations">Cancel</a>
                </div>
        </form>
        </div>
</main>
<%- include ('partials/footer') %>