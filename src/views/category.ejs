<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <% if (errorMessage) { %>
        <p class="error"><%= errorMessage %></p>
    <% } %>

    <% if (category) { %>
        <h2><%= category.category_name %></h2>
        <% if (category.description) { %>
            <p><%= category.description %></p>
        <% } %>

        <% if (projects && projects.length) { %>
            <h3>Service Projects in this Category</h3>
            <ul>
                <% projects.forEach((project) => { %>
                    <li><a href="/project/<%= project.project_id %>"><%= project.title %></a> — <%= project.project_date %></li>
                <% }) %>
            </ul>
        <% } else { %>
            <p>No projects found for this category.</p>
        <% } %>
    <% } else { %>
        <p>Category not found.</p>
    <% } %>
    <% if (category) { %>
        <div class="page-actions">
            <div class="page-actions-left">
                <a class="btn btn-back" href="/categories">Back</a>
            </div>
            <div class="page-actions-right">
                <a class="btn btn-primary" href="/edit-category/<%= category.category_id %>">Update Category Information</a>
            </div>
        </div>
    <% } %>
</main>
<%- include('partials/footer') %>
