<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    
    <% if (errorMessage) { %>
        <p class="error"><%= errorMessage %></p>
    <% } %>

    <% if (project) { %>
        <div class="project-details">
            <h2><%= project.title %></h2>
            
            <% if (project.description) { %>
                <p><strong>Description:</strong> <%= project.description %></p>
            <% } %>
            
            <p><strong>Date:</strong> <%= project.project_date %></p>
            
            <% if (project.project_location) { %>
                <p><strong>Location:</strong> <%= project.project_location %></p>
            <% } %>
            
            <% if (project.organization_name) { %>
                <p><strong>Organization:</strong> <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a></p>
            <% } %>
            
            <% if (project.categories && project.categories.length) { %>
                <p><strong>Categories:</strong>
                <% project.categories.forEach((cat, idx) => { %>
                    <a class="tag" href="/category/<%= cat.category_id %>"><%= cat.category_name %></a><%= idx < project.categories.length - 1 ? ' ' : '' %>
                <% }) %>
                </p>
            <% } %>
        </div>
    <% } %>
    <% if (project) { %>
        <div class="page-actions">
            <div class="page-actions-left">
                <a class="btn btn-back" href="/projects">Back</a>
            </div>
            <div class="page-actions-center">
                <a class="btn btn-primary" href="/edit-project/<%= project.project_id %>">Update Project</a>
            </div>
            <div class="page-actions-right">
                <a class="btn btn-primary" href="/assign-categories/<%= project.project_id %>">Update Project Categories</a>
            </div>
        </div>
    <% } %>
</main>
<%- include('partials/footer') %>
