<%- include('partials/header') %>
<main>
    <h1><%= projectDetails.title %></h1>

    <h2>Assign Categories</h2>
 <div class="project-form">
 <form action="/assign-categories/<%= projectId %>" method="POST">

    <div class="form-group checkbox-grid">
      <% categories.forEach(category => { %>
        <div>
          <input
            type="checkbox"
            id="category-<%= category.category_id %>"
            name="categoryIds"
            value="<%= category.category_id %>"
            <%= assignedCategories.some(ac => ac.category_id === category.category_id) ? 'checked' : '' %>
          />
          <label for="category-<%= category.category_id %>"><%= category.category_name %></label>
        </div>
      <% }); %>
    </div>

    <div class="category-actions">
      <button class="btn btn-primary" type="submit">Update Categories</button>
      <a class="btn btn-secondary" href="/project/<%= projectId %>">Cancel</a>
    </div>
  </form>
  </div>

</main>
<%- include('partials/footer') %>