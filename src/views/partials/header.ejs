<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <nav>
        <div class="nav-inner">
            <ul class="menu">
                <li><a href="/">Home</a></li>
                <li><a href="/organizations">Organizations</a></li>
                <li><a href="/projects">Projects</a></li>
                <li><a href="/categories">Categories</a></li>
            </ul>

            <div class="nav-actions">
                <% if (isLoggedIn) { %>
                    <a class="auth-btn auth-logout" href="/logout">Logout</a>
                <% } else { %>
                    <a class="auth-btn auth-register" href="/register">Register</a>
                    <a class="auth-btn auth-login" href="/login">Login</a>
                <% } %>
            </div>
        </div>
    </nav>
    <% const messages = flash(); %>
    <% Object.keys(messages).forEach(type => { %>
        <% if (messages[type].length > 0) { %>
            
                <% messages[type].forEach(msg => { %>
                    <%= msg %>
                <% }); %>
            
        <% } %>
    <% }); %>