<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <% if (errorMessage) { %>
        <p class="error"><%= errorMessage %></p>
    <% } %>

    <% if (projects && projects.length) { %>
        <ul>
            <% projects.forEach((project) => { %>
                <li>
                    <!-- Make the project title a link to the project details page -->
                    <strong><a href="/project/<%= project.project_id %>"><%= project.title %></a></strong>
                    
                    <!-- Display the organization name as a link to the organization details page -->
                    <% if (project.organization_name) { %>
                        <p>Organization: <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a></p>
                    <% } %>
                    
                    <!-- Display other project details -->
                    <% if (project.description) { %>
                        <p><%= project.description %></p>
                    <% } %>
                    
                    <p>
                        <% if (project.project_location) { %>
                            Location: <%= project.project_location %> | 
                        <% } %>
                        Date: <%= project.project_date %>
                    </p>
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>No upcoming service projects available.</p>
    <% } %>
    <p><a href="/new-project">Add a New Service Project</a></p>
</main>
<%- include('partials/footer') %>