<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <h2>Upcoming Service Projects</h2>

    <% if (errorMessage) { %>
        <p class="error"><%= errorMessage %></p>
    <% } %>

    <% if (organizations && organizations.length) { %>
        <% organizations.forEach((organization) => { %>
            <section class="organization-group">
                <h3><%= organization.organization_name %></h3>
                <ul>
                    <% organization.projects.forEach((project) => { %>
                        <li>
                            <strong><%= project.title %></strong> - <%= project.description %> (Location: <%= project.project_location %>, Date: <%= project.project_date.toDateString() %>)
                        </li>
                    <% }) %>
                </ul>
            </section>
        <% }) %>
    <% } else { %>
        <p>No upcoming service projects available.</p>
    <% } %>
</main>
<%- include('partials/footer') %>