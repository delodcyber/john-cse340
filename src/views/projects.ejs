<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <h2>Upcoming Service Projects</h2>

    <% if (errorMessage) { %>
        <p class="error"><%= errorMessage %></p>
    <% } %>

    <ul>
        <% if (projects && projects.length) { %>
            <% projects.forEach((project) => { %>
                <li>
                    <strong><%= project.title %></strong> - <%= project.description %> (Organization: <%= project.organization_name || 'Unknown' %>, Location: <%= project.project_location %>, Date: <%= project.project_date.toDateString() %>)
                </li>
            <% }) %>
        <% } else { %>
            <li>No upcoming service projects available.</li>
        <% } %>
    </ul>
</main>
<%- include('partials/footer') %>