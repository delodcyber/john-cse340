<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <p>Here are a few of our partner organizations:</p>

    <% if (errorMessage) { %>
        <p class="error"><%= errorMessage %></p>
    <% } %>

    <ul>
        <% if (organizations && organizations.length) { %>
            <% organizations.forEach((organization) => { %>
                <li>
                    <% if (organization.logo_filename) { %>
                        <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.organization_name %> logo">
                    <% } %>
                    <strong><%= organization.organization_name %></strong>
                    <p><a href="mailto:<%= organization.contact_email %>"><%= organization.contact_email %></a></p>
                    <% if (organization.description) { %>
                        <p><%= organization.description %></p>
                    <% } %>
                </li>
            <% }) %>
        <% } else { %>
            <li>No organizations are available at this time.</li>
        <% } %>
    </ul>
</main>
<%- include('partials/footer') %>

