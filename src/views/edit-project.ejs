<%- include('partials/header') %>
<main>
	<h1><%= title %></h1>

	<div class="project-form">
		<form action="/edit-project/<%= project.project_id %>" method="POST">
			<div class="form-group">
				<label for="title">Title</label>
				<input type="text" id="title" name="title" value="<%= project.title %>" maxlength="200" required />
			</div>

			<div class="form-group">
				<label for="description">Description</label>
				<textarea id="description" name="description" maxlength="1000" required><%= project.description %></textarea>
			</div>

			<div class="form-group">
				<label for="location">Location</label>
				<input type="text" id="location" name="location" value="<%= project.project_location %>" maxlength="200" required />
			</div>

			<div class="form-group">
				<label for="date">Date</label>
				<input type="date" id="date" name="date" value="<%= project.project_date ? project.project_date.toISOString().slice(0,10) : '' %>" required />
			</div>

			<div class="form-group">
				<label for="organizationId">Organization</label>
				<select id="organizationId" name="organizationId" required>
					<option value="">-- Select Organization --</option>
					<% organizations.forEach(org => { %>
						<option value="<%= org.organization_id %>" <%= org.organization_id === project.organization_id ? 'selected' : '' %>><%= org.organization_name %></option>
					<% }) %>
				</select>
			</div>

			<div class="category-actions">
				<button class="btn btn-primary" type="submit">Update Project</button>
				<a class="btn btn-secondary" href="/project/<%= project.project_id %>">Cancel</a>
			</div>
		</form>
	</div>
</main>
<%- include('partials/footer') %>
